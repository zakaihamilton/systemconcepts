# Public application URL used when generating absolute links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Logging: debug, info, warn, error, or silent.
NEXT_PUBLIC_LOG_LEVEL=debug
LOG_LEVEL=debug

# MongoDB-backed accounts and personal data (optional for public/offline UI).
MONGO_URL=
MONGO_DB=

# AWS-compatible storage (optional unless AWS storage is enabled).
AWS_ENDPOINT=
AWS_BUCKET=
AWS_ID=
AWS_SECRET=

# Required in production to authorize public RSS media and transcript links.
RSS_MEDIA_SECRET=

# Wasabi public/proxy base URL (optional unless Wasabi storage is enabled).
WASABI_URL=

# Password-reset email delivery (optional).
GMAIL_USER=
GMAIL_PASSWORD=
GMAIL_FROM=
